# Synapse Configuration
# Copy this to .env and edit as needed

# LLM
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_FALLBACK_MODEL=llama3

# Paths
SYNAPSE_DATA_DIR=./data
CHROMA_PATH=./data/chroma
SQLITE_PATH=./data/synapse.db

# Perception
WATCH_PATHS=~/projects,~/Documents
SCREEN_CAPTURE_INTERVAL=5
FILE_WATCHER_WARMUP_DELAY=5

# Features
HUD_ENABLED=true
VOICE_ENABLED=false
AUTO_ACT=false

# Memory
MEMORY_MAX_EPISODES=10000
MEMORY_RETENTION_DAYS=90

# Rule Engine
RULE_ENGINE_ENABLED=true
RULE_ENGINE_EVAL_INTERVAL=30

# Collectors
RSS_POLL_INTERVAL=300
RSS_EXTRA_FEED_URLS=
# Path to your local calendar .ics file (Google Calendar export, Outlook, etc.)
# Leave empty to disable calendar-based rules
CALENDAR_ICS_PATH=
CALENDAR_LOOKAHEAD_HOURS=4
